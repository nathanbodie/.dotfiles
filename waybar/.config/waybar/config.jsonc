{
    "font": "JetBrainsMono Nerd Font",
    "reload_style_on_change": true,
    "width": 1920, // Waybar width
    "spacing": 7, // Gaps between modules (4px)
    "modules-left": [
        "group/quicklinks-left",
        // "wlr/taskbar",
        "network",
        "hyprland/window",
    ],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [
        "mpd",
        "pulseaudio",
        "group/hardware",
        "custom/keyboard",
        "clock",
        "group/quicklinks-right",
    ],

    //Taskbar
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": "20",
        "on-click": "activate",
        "on-click-right": "close",
        "tooltip-format": "Go to {title}",
        "ignore-list": ["kitty", "kitty-scratchpad"],
    },

    // Hyprland
    "hyprland/workspaces": {
        "disable-scroll": false,
        "sort-by": "number",
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        //"format-icons": {
        //  "1": "’äĪ ",
        //  "2": "’Æł ",
        //  "3": "’äö ",
        //},
    },
    "hyprland/window": {
        "format": "{title}",
        "icon": true,
        "icon-size": 20,
        "max-length": 30,
        "separate-outputs": true,
        "rewrite": {
            "(.*) - Brave": "$1",
        },
    },

    // Tray
    "tray": {
        "icon-size": 21,
        "spacing": 10,
    },

    // Quicklinks
    "group/quicklinks-left": {
        "orientation": "horizontal",
        "modules": [
            "image",
            "custom/claude",
            "custom/settings",
            "custom/clipboard",
        ],
    },
    "image": {
        "path": "/home/hrigved/Pictures/Icons/arch.png",
        "on-click": "~/.config/rofi/menus/drun.sh",
        "size": 18,
    },
    "custom/claude": {
        "format": "  ",
        "tooltip": true,
        "tooltip-format": "Open Claude AI!",
        "on-click": "brave --app=https://claude.ai",
    },
    "custom/settings": {
        "format": "’Ćō ",
        "tooltip": true,
        "tooltip-format": "Open Settings!",
        "on-click": "systemsettings",
    },
    "custom/clipboard": {
        "format": "¾▒śó ",
        "tooltip": true,
        "tooltip-format": "Open Clipboard Manager!",
        "on-click": "~/.config/rofi/menus/clipboard.sh",
    },
    //"custom/terminal": {
    //  "format": "’äĀ ",
    //  "tooltip": true,
    //  "tooltip-format": "’äĀ Open Kitty!",
    //  "on-click": "kitty",
    //},
    //"custom/browser": {
    //  "format": "’Æł ",
    //  "tooltip": true,
    //  "tooltip-format": "’Æł Open Brave!",
    //  "on-click": "brave",
    //},
    //"custom/explorer": {
    //  "format": "’ōö ",
    //  "tooltip": true,
    //  "tooltip-format": "’ōö Open Dolphin!",
    //  "on-click": "dolphin",
    //},

    "group/quicklinks-right": {
        "orientation": "horizontal",
        "modules": [
            "idle_inhibitor",
            // "custom/wallpaper",
            "custom/notification",
            "custom/power-menu",
        ],
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü« ",
            "deactivated": "’ü░ ",
        },
    },
    //"group/power-menu": {
    //  "orientation": "inherit",
    //  "drawer": {
    //    "transition-duration": 500,
    //    "children-class": "power-child",
    //    "transition-left-to-right": false,
    //  },
    //  "modules": [
    //    "custom/wlogout",
    //    "custom/reboot",
    //    "custom/quit",
    //    "custom/suspend",
    //    "custom/lock",
    //  ],
    //},
    "custom/power-menu": {
        "format": "’Ćæ ",
        "tooltip": true,
        "tooltip-format": "’Ćæ Open Wlogout!",
        "on-click": "~/.config/hypr/scripts/power-menu.sh",
    },
    //"custom/lock": {
    //  "format": "’ĆŻ ",
    //  "on-click": "hyprlock",
    //},
    //"custom/quit": {
    //  "format": "¾░Źā ",
    //  "on-click": "hyprctl dispatch exit",
    //},
    //"custom/suspend": {
    //  "format": "ŌÅŠ ",
    //  "on-click": "systemctl suspend",
    //},
    //"custom/reboot": {
    //  "format": "Ņ½Æ ",
    //  "on-click": "systemctl reboot",
    //},
    "custom/wallpaper": {
        "format": "’ĆŠ ",
        "tooltip": true,
        "tooltip-format": "’ĆŠ Change Wallpaper!",
        "on-click": "~/.config/rofi/menus/swww.sh",
    },
    "custom/notification": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "’æČ<span foreground='red'><sup>’æä</sup></span>",
            "none": "’ÆÜ",
            "dnd-notification": "’æĖ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-none": "’æĖ",
            "inhibited-notification": "’æČ<span foreground='red'><sup>’æä</sup></span>",
            "inhibited-none": "’ÆÜ",
            "dnd-inhibited-notification": "’æĖ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-inhibited-none": "’æĖ",
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },

    // Settings
    "group/settings": {
        "orientation": "horizontal",
        "modules": [],
    },

    // Temperature
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:01.0/0000:01:00.0/nvme/nvme0/hwmon1/temp1_input",
        "format-icons": ["’Ø½", "’ŗē", "’Ø®"],
    },

    // Current Keyboard Layout
    "custom/keyboard": {
        "exec": "~/.config/hypr/scripts/waybar-kb-layout.sh",
        "on-click": "~/.config/hypr/scripts/change-kb-layout.sh",
        "return-type": "json",
        "interval": 1,
        "format": "{} <span font='16' rise='-1800'>¾░īī </span>",
    },

    // Audio setup
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
        "format-muted": "¾░Ø¤ {format_source}",
        "format-source": "{volume}%",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦ ", "’Ć© "],
        },
        "max-volume": 150,
        "on-click": "pavucontrol",
    },

    // Network setup
    "network": {
        "format": "{ifname}",
        "format-wifi": "’ć½  {essid} {bandwidthDownBytes}",
        "format-ethernet": "ŅĮä  {bandwidthDownBytes}",
        "format-disconnected": "¾▒Źó No Internet",
        "tooltip-format": "¾░ŖŚ {ifname} via {gwaddr}",
        "tooltip-format-wifi": "’ć½  {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "ŅĮä  {ifname}",
        "max-length": 50,
        "interval": 2,
    },

    // Hardware info
    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory"],
    },
    "disk": {
        "format": "{percentage_used}% ŅĘ® ",
        "interval": 5,
        "path": "/home",
    },
    "cpu": {
        "format": "{usage}% ’ŗø ",
        "interval": 5,
        "tooltip": false,
    },
    "memory": {
        "format": " {}% Ņē” ",
        "interval": 5,
    },

    // Clock
    "clock": {
        "format": "<span font='12.5'>¾▒æé</span> {:%a%e %b %I:%M %p}", // Thu 7 Oct 9:28 AM
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // "format-alt": "¾░©│ {:%d %b %Y}", // 25 Dec 2006
    },
}
